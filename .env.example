# Copy to .env and fill in. .env is git-ignored.

# Apify — used by BOTH trend-scout (scrapes peer Pages for trends) and
# performance-tracker (scrapes our own posts' PUBLIC metrics by URL).
APIFY_API_TOKEN=

# Optional: override the Apify actor IDs (defaults also live in data/seeds.yaml).
# APIFY_TRENDS_ACTOR=apify/facebook-posts-scraper
# APIFY_POST_ACTOR=apify/facebook-post-scraper
