# Secrets
.env
.env.local

# Private Meta exports (may contain non-public Insights). Per-Brand under
# data/brands/<slug>/your-data/. Keep the folders, ignore their contents.
data/brands/*/your-data/*
!data/brands/*/your-data/.gitkeep

# Legacy/root private Meta exports — never commit anything dropped here.
data/your-data/

# Produced Asset media (the Save phase's downloaded slides/clips — ~8 MB per carousel). Durable on
# the Operator's disk beside the Brief/Spec; the ledger's asset_paths point here. Too heavy for git.
data/brands/*/ideas/**/*.assets/

# Node / TypeScript build
node_modules/
dist/
*.tsbuildinfo

# Scratch
*.tmp
*.log
.DS_Store
